{
    "containerDefinitions": [
        {
            "name": "studentperformance",
            "image": "775615218887.dkr.ecr.us-east-1.amazonaws.com/studentperformance",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 5000,
                    "hostPort": 5000,
                    "protocol": "tcp",
                    "name": "studentperformance-5000-tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [],
            "mountPoints": [],
            "volumesFrom": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/studentperformance",
                    "awslogs-create-group": "true",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ],
    "family": "studentperformance",
    "executionRoleArn": "arn:aws:iam::775615218887:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["EC2"],
    "cpu": "1024",
    "memory": "2048"
}